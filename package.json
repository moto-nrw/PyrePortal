{
  "name": "pyreportal",
  "private": true,
  "version": "1.5.1",
  "type": "module",
  "packageManager": "pnpm@10.34.4+sha512.8768be55200ae3f2226b6527fcca2687e14bc4e5f12d7721a0f25da3df47915177058648db4177baf348120fa0ba2752d8d8d93f6beaf1fe64ae18da8de961af",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:gkt": "BUILD_TARGET=gkt VITE_API_BASE_URL=https://api.moto-app.de tsc && BUILD_TARGET=gkt VITE_API_BASE_URL=https://api.moto-app.de vite build",
    "build:wedge": "BUILD_TARGET=wedge VITE_API_BASE_URL=https://api.moto-app.de tsc && BUILD_TARGET=wedge VITE_API_BASE_URL=https://api.moto-app.de vite build",
    "dev:wedge": "BUILD_TARGET=wedge VITE_API_BASE_URL=http://localhost:8080 vite",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "check": "eslint src --ext .ts,.tsx && tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\" \"!src-tauri/**\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\" \"!src-tauri/**\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "knip": "knip",
    "screenshots": "playwright test --config playwright.config.ts",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.3.1",
    "@fortawesome/free-solid-svg-icons": "^7.3.1",
    "@fortawesome/react-fontawesome": "^3.5.0",
    "@moto-nrw/design-system": "^0.5.2",
    "@tauri-apps/api": "^2.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.4",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.1",
    "globals": "^17.7.0",
    "happy-dom": "^20.11.0",
    "knip": "^6.27.0",
    "lint-staged": "^17.1.0",
    "postcss": "^8.5.20",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write"
    ],
    "src/**/*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "knip": {
    "project": [
      "src/**/*.{ts,tsx}"
    ],
    "entry": [
      "src/platform/*/index.ts"
    ],
    "ignoreDependencies": [
      "@moto-nrw/design-system",
      "lint-staged"
    ],
    "ignoreBinaries": [
      "lefthook"
    ]
  }
}
